{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "forkProcessing": "enabled",
  "mode": "full",
  "enabledManagers": [
    "poetry",
    "github-actions",
    "git-submodules",
    "custom.regex"
  ],
  "timezone": "America/Chicago",
  "updateNotScheduled": true,
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Dependency Updates (mtjk)",
  "automerge": false,
  "automergeType": "pr",
  "platformAutomerge": false,
  "separateMajorMinor": true,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Automerge all non-major dependency updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest",
        "lockFileMaintenance"
      ],
      "automerge": true,
      "minimumReleaseAge": "12 hours"
    },
    {
      "description": "Hold pandas on v2 until Python/compatibility migration is complete",
      "matchPackageNames": ["pandas"],
      "allowedVersions": "<3"
    },
    {
      "description": "Keep bleak updates manual for planned migration work",
      "matchPackageNames": ["bleak"],
      "automerge": false
    },
    {
      "description": "Automerge protobuf submodule updates",
      "matchManagers": ["git-submodules"],
      "matchDepNames": ["protobufs"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest", "pinDigest"],
      "automerge": true
    },
    {
      "description": "Automerge meshtasticd Docker image updates (digest + version)",
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["meshtastic/meshtasticd"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest", "pinDigest"],
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track meshtasticd Docker image in CI workflows and shell scripts",
      "managerFilePatterns": [
        "/^\\.github/workflows/[^/]+\\.ya?ml$/",
        "/^bin/run-.*-with-meshtasticd\\.sh$/"
      ],
      "matchStrings": [
        "meshtastic/meshtasticd:(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "depNameTemplate": "meshtastic/meshtasticd",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "git-submodules": {
    "enabled": true
  }
}
